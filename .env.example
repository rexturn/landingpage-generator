OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model AI yang digunakan (pilihan: google/gemini-2.5-flash, meta-llama/llama-3.3-70b-instruct, anthropic/claude-3.5-sonnet)
AI_MODEL=google/gemini-2.5-flash

# Max output tokens (4000=hemat, 6000=normal, 8000=panjang)
MAX_TOKENS=6000

# Template engine: vanilla (default) atau react
# vanilla = Tailwind + vanilla JS, ~3500 token output
# react   = React 18 + Babel + Tailwind, lebih interaktif, ~4500 token output
TEMPLATE_TYPE=vanilla

# Bahasa output (id = Bahasa Indonesia, en = English)
LANGUAGE=id

# Folder output untuk hasil generate (setiap proyek jadi subfolder)
OUTPUT_DIR=output

# Nama app (akan muncul di title browser)
APP_NAME=Landing Page Generator

# Folder foto lokal kamu (ganti sesuai lokasi foto di komputermu)
PHOTOS_DIR=photos

# Telegram Bot Token (dari @BotFather)
API_TELEGRAM=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Batasi akses bot hanya ke chat ID tertentu (pisah koma, kosong = semua orang bisa akses)
# Cara cari chat ID: kirim pesan ke bot lalu cek https://api.telegram.org/bot<TOKEN>/getUpdates
ALLOWED_CHAT_IDS=

# Domain suffix untuk URL landing page (tanpa titik di depan)
# Contoh: qtl.web.id → hasil: namaproyek.qtl.web.id
DOMAIN_SUFFIX=qtl.web.id

# Webhook Telegram (kosong = gunakan polling / mode development)
# Contoh: https://bot.namadomain.com
WEBHOOK_URL=
WEBHOOK_PORT=5001

# Cloudflare Account ID — dari https://dash.cloudflare.com → kanan bawah halaman domain
CF_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare API Token — buat di https://dash.cloudflare.com/profile/api-tokens
# Permission: Zone > DNS > Edit
CF_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Zone ID Cloudflare untuk DOMAIN_SUFFIX — dari halaman domain di Cloudflare (kanan bawah)
# Kosong = auto-detect dari domain
CF_ZONE_ID=

# IP/CNAME target DNS record (kosong = auto-detect public IP server)
CF_DNS_TARGET=

# Path ke caddy.json di server (kosong = nonaktifkan integrasi Caddy)
# Kosongkan jika tidak menggunakan Caddy
CADDY_JSON=/etc/caddy/caddy.json