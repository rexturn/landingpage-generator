OPENROUTER_API_KEY=

# Model AI yang digunakan (pilihan: google/gemini-2.5-flash, meta-llama/llama-3.3-70b-instruct, anthropic/claude-3.5-sonnet)
AI_MODEL=google/gemini-2.5-flash

# Bahasa output (id = Bahasa Indonesia, en = English)
LANGUAGE=id

# Folder output untuk hasil generate (setiap proyek jadi subfolder)
OUTPUT_DIR=output

# Nama app (akan muncul di title browser)
APP_NAME=Landing Page Generator

# Folder foto lokal kamu (ganti sesuai lokasi foto di komputermu)
PHOTOS_DIR=photos

# Telegram Bot Token (dari @BotFather)
API_TELEGRAM=

# Domain suffix untuk URL landing page
DOMAIN_SUFFIX=

CF_ACCOUNT_ID=
CF_API_TOKEN=

# Zone ID Cloudflare untuk DOMAIN_SUFFIX (kosong = auto-detect dari domain)
CF_ZONE_ID=

# IP/CNAME target DNS record (kosong = auto-detect public IP server)
CF_DNS_TARGET=